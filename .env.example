# ============================================================
# MenuAI Environment Variables
# Copy this to .env.local (frontend) and .env (backend)
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (transactional emails)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# AI APIs
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
FAL_KEY=your-fal-key

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=menuai-assets
R2_PUBLIC_URL=https://assets.menuai.com

# Backend (FastAPI)
FASTAPI_SECRET_KEY=your-secret-key
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/menuai

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:8000
